# Copy this file to ".env" and fill in your key.
# Get a FREE key at https://console.groq.com/keys
GROQ_API_KEY=

# Password login. Leave BLANK for local use (no login). Set it before hosting
# publicly so only you can access the app.
APP_PASSWORD=
# Optional: extra secret used to sign the session cookie (defaults to the
# password). Set to any random string for a bit more strength.
# SESSION_SECRET=

# Optional overrides
# PORT=3000
# Primary model for analysis/chat, and the lighter model used automatically when
# the primary hits its free-tier daily token cap (429).
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
# GROQ_WHISPER_MODEL=whisper-large-v3-turbo
